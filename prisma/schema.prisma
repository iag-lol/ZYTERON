// Prisma schema for Zyteron platform
// Stage 1: base models to unblock seeds and future stages

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         Role     @default(CLIENT)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  company      String?
  phone        String?
  address      String?
  city         String?
  country      String?  @default("Chile")
  rut          String?
  contactName  String?
  industry     String?
  tier         String?
  notes        String?

  leads       Lead[]
  quotes      Quote[]
  sales       Sale[]
  visits      Visit[]
  sessions    Session[]
  projects    Project[]
  requests    ClientRequest[]
  taxDocuments TaxDocument[]
}

enum Role {
  CLIENT
  ADMIN
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ServiceCategory {
  id       String    @id @default(cuid())
  slug     String    @unique
  name     String
  order    Int       @default(0)
  services Service[]
}

model Service {
  id          String          @id @default(cuid())
  slug        String          @unique
  name        String
  description String
  shortCopy   String
  features    String[]
  priceFrom   Int?
  categoryId  String
  category    ServiceCategory @relation(fields: [categoryId], references: [id])
  faqs        FAQ[]
  seoId       String?         @unique
  seo         SeoMetadata?    @relation("ServiceSeo", fields: [seoId], references: [id])
  createdAt   DateTime        @default(now())
}

model ProductCategory {
  id       String    @id @default(cuid())
  slug     String    @unique
  name     String
  order    Int       @default(0)
  products Product[]
}

model Product {
  id          String          @id @default(cuid())
  slug        String          @unique
  name        String
  description String
  price       Int
  discountPct Int             @default(0)
  stock       Int             @default(10)
  featured    Boolean         @default(false)
  categoryId  String
  category    ProductCategory @relation(fields: [categoryId], references: [id])
  faqs        FAQ[]
  badges      String[]
  seoId       String?         @unique
  seo         SeoMetadata?    @relation("ProductSeo", fields: [seoId], references: [id])
  createdAt   DateTime        @default(now())
}

model Plan {
  id          String       @id @default(cuid())
  slug        String       @unique
  name        String
  description String
  price       Int
  tier        PlanTier
  freeGifts   String[]
  features    String[]
  popular     Boolean      @default(false)
  quotes      Quote[]
  seoId       String?      @unique
  seo         SeoMetadata? @relation("PlanSeo", fields: [seoId], references: [id])
}

enum PlanTier {
  BASIC
  INTERMEDIATE
  PRO
}

model Extra {
  id          String        @id @default(cuid())
  slug        String        @unique
  name        String
  category    ExtraCategory
  description String
  options     String[]
  price       Int?
  quoteExtras QuoteExtra[]
}

enum ExtraCategory {
  DOMAIN
  EMAIL
  SUPPORT
  EQUIPMENT
  SEO
  DESIGN
  TRAINING
  TECH
}

model Quote {
  id        String       @id @default(cuid())
  userId    String?
  user      User?        @relation(fields: [userId], references: [id])
  planId    String?
  plan      Plan?        @relation(fields: [planId], references: [id])
  extras    QuoteExtra[]
  name      String
  email     String
  phone     String?
  company   String?
  message   String?
  subtotal  Int
  discount  Int          @default(0)
  total     Int
  status    QuoteStatus  @default(PENDING)
  createdAt DateTime     @default(now())
  taxDocuments TaxDocument[]
  projects   Project[]
}

model QuoteExtra {
  id       String @id @default(cuid())
  quoteId  String
  extraId  String
  quantity Int    @default(1)
  quote    Quote  @relation(fields: [quoteId], references: [id])
  extra    Extra  @relation(fields: [extraId], references: [id])
}

enum QuoteStatus {
  PENDING
  SENT
  WON
  LOST
}

model Lead {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  name      String
  email     String
  phone     String?
  source    String?
  message   String?
  type      LeadType
  createdAt DateTime @default(now())
}

model WebDiscount {
  id          String             @id @default(cuid())
  name        String
  description String?
  targetType  DiscountTargetType @default(ORDER)
  targetId    String?
  mode        DiscountMode       @default(PERCENT)
  value       Int
  minSubtotal Int?               @default(0)
  active      Boolean            @default(true)
  startsAt    DateTime?
  endsAt      DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}

model ClientReview {
  id         String       @id @default(cuid())
  name       String
  email      String?
  company    String?
  rating     Int
  comment    String
  service    String?
  status     ReviewStatus @default(PENDING)
  source     String?
  createdAt  DateTime     @default(now())
  approvedAt DateTime?
}

model Visit {
  id        String   @id @default(cuid())
  clientId  String?
  client    User?    @relation(fields: [clientId], references: [id])
  date      DateTime?
  notes     String?
  status    String?
  createdAt DateTime @default(now())
}

model Sale {
  id            String         @id @default(cuid())
  clientId      String?
  client        User?          @relation(fields: [clientId], references: [id])
  total         Int
  description   String?
  paymentMethod String?
  invoiceRef    String?
  createdAt     DateTime       @default(now())
  projects      Project[]
  taxDocuments  TaxDocument[]
}

model Project {
  id             String          @id @default(cuid())
  clientId       String?
  client         User?           @relation(fields: [clientId], references: [id])
  quoteId        String?
  quote          Quote?          @relation(fields: [quoteId], references: [id])
  saleId         String?
  sale           Sale?           @relation(fields: [saleId], references: [id])
  title          String
  serviceArea    String?
  status         String?
  priority       String?
  startDate      DateTime?
  startTime      String?
  endDate        DateTime?
  endTime        String?
  description    String?
  scope          String?
  hourlyRate     Int?
  estimatedHours Int?
  actualHours    Int?
  totalCharge    Int?
  owner          String?
  createdAt      DateTime        @default(now())
  requests       ClientRequest[]
  taxDocuments   TaxDocument[]
}

model ClientRequest {
  id          String   @id @default(cuid())
  clientId    String?
  client      User?    @relation(fields: [clientId], references: [id])
  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id])
  subject     String
  channel     String?
  priority    String?
  status      String?
  description String?
  dueDate     DateTime?
  createdAt   DateTime @default(now())
}

model TaxDocument {
  id             String   @id @default(cuid())
  clientId       String?
  client         User?    @relation(fields: [clientId], references: [id])
  projectId      String?
  project        Project? @relation(fields: [projectId], references: [id])
  quoteId        String?
  quote          Quote?   @relation(fields: [quoteId], references: [id])
  saleId         String?
  sale           Sale?    @relation(fields: [saleId], references: [id])
  type           String
  documentNumber String?
  siiFolio       String?
  issueDate      DateTime?
  dueDate        DateTime?
  netAmount      Int?
  taxAmount      Int?
  totalAmount    Int?
  status         String?
  paymentStatus  String?
  emissionMethod String?
  pdfUrl         String?
  xmlUrl         String?
  notes          String?
  createdAt      DateTime @default(now())
}

enum LeadType {
  CONTACT
  QUOTE
  PACKAGE_BUILDER
}

enum DiscountTargetType {
  PLAN
  EXTRA
  PRODUCT
  ORDER
}

enum DiscountMode {
  PERCENT
  FIXED
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

model FAQ {
  id        String   @id @default(cuid())
  question  String
  answer    String
  service   Service? @relation(fields: [serviceId], references: [id])
  serviceId String?
  product   Product? @relation(fields: [productId], references: [id])
  productId String?
  category  String?
  createdAt DateTime @default(now())
}

model SeoMetadata {
  id              String   @id @default(cuid())
  metaTitle       String
  metaDescription String
  slug            String   @unique
  canonicalUrl    String?
  ogTitle         String?
  ogDescription   String?
  ogImage         String?
  keywords        String[]
  jsonLd          Json?
  noindex         Boolean  @default(false)
  service         Service? @relation("ServiceSeo")
  product         Product? @relation("ProductSeo")
  plan            Plan?    @relation("PlanSeo")
}

model Banner {
  id       String  @id @default(cuid())
  title    String
  body     String
  ctaLabel String?
  ctaHref  String?
  active   Boolean @default(true)
}

model Setting {
  id    String      @id @default(cuid())
  key   String      @unique
  value String
  type  SettingType @default(TEXT)
}

enum SettingType {
  TEXT
  JSON
  BOOLEAN
}
